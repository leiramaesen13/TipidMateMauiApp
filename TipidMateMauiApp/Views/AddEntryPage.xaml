<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TipidMateMauiApp.ViewModels"
             x:Class="TipidMateMauiApp.Views.AddEntryPage"
             x:DataType="vm:MainViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8FAFB">
    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" BackgroundColor="White" Padding="18,46,18,13">
            <Grid.Shadow>
                <Shadow Brush="Black" Opacity="0.04" Radius="4" Offset="0,1"/>
            </Grid.Shadow>
            <Grid ColumnDefinitions="Auto,*">
                <Button Grid.Column="0" Text="← Back"
                        BackgroundColor="Transparent" TextColor="#00897B"
                        FontSize="14" Clicked="OnBackClicked"/>
                <Label x:Name="PageTitleLabel" Grid.Column="1"
                       Text="New Entry" FontSize="18" FontAttributes="Bold"
                       TextColor="#1C2B2B" VerticalOptions="Center"/>
            </Grid>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="14,14,14,40" Spacing="12">

                <!-- Main Entry Card -->
                <Border BackgroundColor="White" StrokeShape="RoundRectangle 18"
                        Stroke="#E2EAEA" StrokeThickness="1" Padding="18">
                    <Border.Shadow>
                        <Shadow Brush="#00897B" Opacity="0.05" Radius="8" Offset="0,2"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="0">

                        <!-- Type Toggle -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10"
                              Margin="0,0,0,18">
                            <Border Grid.Column="0" x:Name="ExpenseBtnBorder"
                                    StrokeShape="RoundRectangle 13"
                                    Stroke="Transparent">
                                <Button x:Name="ExpenseBtnInner" Text="↓  Expense"
                                        FontSize="13" FontAttributes="Bold"
                                        BackgroundColor="#C62828" TextColor="White"
                                        Clicked="OnExpenseClicked"/>
                            </Border>
                            <Border Grid.Column="1" x:Name="IncomeBtnBorder"
                                    StrokeShape="RoundRectangle 13"
                                    Stroke="Transparent">
                                <Button x:Name="IncomeBtnInner" Text="↑  Income"
                                        FontSize="13" FontAttributes="Bold"
                                        BackgroundColor="#F1F5F5"
                                        TextColor="#90A4A4"
                                        Clicked="OnIncomeClicked"/>
                            </Border>
                        </Grid>

                        <!-- Amount -->
                        <Border BackgroundColor="#F8FAFB"
                                StrokeShape="RoundRectangle 14"
                                Stroke="Transparent" Padding="14"
                                Margin="0,0,0,18">
                            <VerticalStackLayout Spacing="7">
                                <Label Text="AMOUNT (₱)" FontSize="9"
                                       FontAttributes="Bold" TextColor="#90A4A4"
                                       CharacterSpacing="2"
                                       HorizontalOptions="Center"/>
                                <Grid ColumnDefinitions="Auto,*"
                                      HorizontalOptions="Center">
                                    <Label Grid.Column="0" Text="₱" FontSize="24"
                                           TextColor="#90A4A4"
                                           VerticalOptions="End"
                                           Margin="0,0,4,5"/>
                                    <Entry x:Name="AmountEntry" Grid.Column="1"
                                           Text="{Binding FormAmount}"
                                           Placeholder="0.00"
                                           PlaceholderColor="#CCCCCC"
                                           FontSize="44" FontAttributes="Bold"
                                           TextColor="#C62828" Keyboard="Numeric"
                                           WidthRequest="190"
                                           BackgroundColor="Transparent"/>
                                </Grid>
                                <BoxView x:Name="AmountUnderline" HeightRequest="3"
                                         CornerRadius="2" Color="#C62828"
                                         Margin="40,0"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Description -->
                        <Label Text="DESCRIPTION" FontSize="9"
                               FontAttributes="Bold" TextColor="#90A4A4"
                               CharacterSpacing="1" Margin="0,0,0,6"/>
                        <Border BackgroundColor="#F8FAFB"
                                StrokeShape="RoundRectangle 11"
                                Stroke="#E2EAEA" StrokeThickness="1.5"
                                Margin="0,0,0,13">
                            <Entry Text="{Binding FormDescription}"
                                   Placeholder="What was this for?"
                                   PlaceholderColor="#90A4A4"
                                   TextColor="#1C2B2B" FontSize="14"
                                   Margin="4,0" BackgroundColor="Transparent"/>
                        </Border>

                        <!-- Date -->
                        <Label Text="DATE" FontSize="9" FontAttributes="Bold"
                               TextColor="#90A4A4" CharacterSpacing="1"
                               Margin="0,0,0,6"/>
                        <Border BackgroundColor="#F8FAFB"
                                StrokeShape="RoundRectangle 11"
                                Stroke="#E2EAEA" StrokeThickness="1.5"
                                Margin="0,0,0,17">
                            <DatePicker Date="{Binding FormDate}"
                                        TextColor="#1C2B2B" FontSize="14"
                                        Format="MMMM dd, yyyy"
                                        BackgroundColor="Transparent"
                                        Margin="8,4"/>
                        </Border>

                        <!-- Category -->
                        <Label Text="CATEGORY" FontSize="9" FontAttributes="Bold"
                               TextColor="#90A4A4" CharacterSpacing="1"
                               Margin="0,0,0,9"/>
                        <Grid x:Name="CategoryGrid"
                              ColumnDefinitions="*,*,*,*"
                              RowDefinitions="Auto,Auto"
                              ColumnSpacing="7" RowSpacing="7"
                              Margin="0,0,0,20"/>

                        <!-- ══ RECURRING TOGGLE ══ -->
                        <BoxView Color="#F0F4F4" HeightRequest="1"
                                 Margin="0,0,0,14"/>

                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12" Margin="0,0,0,4">
                            <Label Grid.Column="0" Text="🔁" FontSize="22"
                                   VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="1"
                                                 VerticalOptions="Center">
                                <Label Text="Recurring Transaction"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#2D2D35"/>
                                <Label Text="Auto-add on a schedule"
                                       FontSize="11" TextColor="#9898A6"/>
                            </VerticalStackLayout>
                            <Switch x:Name="RecurringSwitch"
                                    Grid.Column="2"
                                    OnColor="#4ECDC4" ThumbColor="White"
                                    VerticalOptions="Center"
                                    Toggled="OnRecurringSwitchToggled"/>
                        </Grid>

                        <!-- Frequency Picker (shown when recurring ON) -->
                        <VerticalStackLayout x:Name="FrequencyPanel"
                                             IsVisible="False"
                                             Spacing="10"
                                             Margin="0,10,0,0">
                            <Label Text="REPEAT EVERY" FontSize="9"
                                   FontAttributes="Bold" TextColor="#9898A6"
                                   CharacterSpacing="1"/>
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">

                                <!-- Daily -->
                                <Border x:Name="DailyBtn" Grid.Column="0"
                                        StrokeShape="RoundRectangle 12"
                                        Stroke="#E2EAEA"
                                        BackgroundColor="#F8FAFB"
                                        Padding="0,12">
                                    <VerticalStackLayout Spacing="3"
                                                         HorizontalOptions="Center">
                                        <Label Text="📅" FontSize="20"
                                               HorizontalOptions="Center"/>
                                        <Label Text="Daily" FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="#9898A6"
                                               HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Tapped="OnFrequencyTapped"
                                            CommandParameter="daily"/>
                                    </Border.GestureRecognizers>
                                </Border>

                                <!-- Weekly -->
                                <Border x:Name="WeeklyBtn" Grid.Column="1"
                                        StrokeShape="RoundRectangle 12"
                                        Stroke="#4ECDC4"
                                        BackgroundColor="#E8FBF8"
                                        Padding="0,12">
                                    <VerticalStackLayout Spacing="3"
                                                         HorizontalOptions="Center">
                                        <Label Text="📆" FontSize="20"
                                               HorizontalOptions="Center"/>
                                        <Label Text="Weekly" FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="#4ECDC4"
                                               HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Tapped="OnFrequencyTapped"
                                            CommandParameter="weekly"/>
                                    </Border.GestureRecognizers>
                                </Border>

                                <!-- Monthly -->
                                <Border x:Name="MonthlyBtn" Grid.Column="2"
                                        StrokeShape="RoundRectangle 12"
                                        Stroke="#E2EAEA"
                                        BackgroundColor="#F8FAFB"
                                        Padding="0,12">
                                    <VerticalStackLayout Spacing="3"
                                                         HorizontalOptions="Center">
                                        <Label Text="🗓️" FontSize="20"
                                               HorizontalOptions="Center"/>
                                        <Label Text="Monthly" FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="#9898A6"
                                               HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Tapped="OnFrequencyTapped"
                                            CommandParameter="monthly"/>
                                    </Border.GestureRecognizers>
                                </Border>

                            </Grid>

                            <!-- Next run preview -->
                            <Border BackgroundColor="#E8FBF8"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="#4ECDC433" Padding="12,8">
                                <Label x:Name="NextRunPreviewLabel"
                                       FontSize="12" TextColor="#2D2D35"
                                       FontAttributes="Bold"/>
                            </Border>
                        </VerticalStackLayout>

                        <BoxView Color="#F0F4F4" HeightRequest="1"
                                 Margin="0,14,0,14"/>

                        <!-- Save Button -->
                        <Border x:Name="SaveBtnBorder"
                                StrokeShape="RoundRectangle 13"
                                Stroke="Transparent">
                            <Border.Shadow>
                                <Shadow Brush="#00897B" Opacity="0.25"
                                        Radius="8" Offset="0,4"/>
                            </Border.Shadow>
                            <Button x:Name="SaveBtn" Text="✓  Save Entry"
                                    TextColor="White" FontSize="15"
                                    FontAttributes="Bold"
                                    BackgroundColor="Transparent"
                                    Clicked="OnSaveClicked"/>
                        </Border>

                        <!-- Cancel -->
                        <Button x:Name="CancelBtn" Text="Cancel"
                                BackgroundColor="#F1F5F5" TextColor="#90A4A4"
                                FontSize="13" FontAttributes="Bold"
                                CornerRadius="13" IsVisible="False"
                                Margin="0,9,0,0"
                                Clicked="OnCancelClicked"/>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>