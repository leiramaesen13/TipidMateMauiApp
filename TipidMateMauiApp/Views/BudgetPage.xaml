<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TipidMateMauiApp.ViewModels"
             x:Class="TipidMateMauiApp.Views.BudgetPage"
             x:DataType="vm:MainViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FAF9F6">
    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ── HEADER ── -->
        <Grid Grid.Row="0" BackgroundColor="White" Padding="22,52,22,16">
            <Grid ColumnDefinitions="Auto,*">
                <Button Grid.Column="0" Text="← Back" BackgroundColor="Transparent"
                        TextColor="#4ECDC4" FontSize="14" Clicked="OnBackClicked"/>
                <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                    <Label Text="🎯 Budget Limits" FontSize="20" FontAttributes="Bold"
                           TextColor="#2D2D35"/>
                    <Label x:Name="PeriodSubtitle"
                           Text="Set monthly limits per category"
                           FontSize="12" TextColor="#9898A6"/>
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- ── PERIOD TOGGLE ── -->
        <Grid Grid.Row="1" BackgroundColor="White"
              Padding="16,0,16,16" ColumnDefinitions="*,*">

            <!-- Monthly Tab -->
            <Border x:Name="MonthlyTabBorder"
                    Grid.Column="0"
                    BackgroundColor="#4ECDC4"
                    StrokeShape="RoundRectangle 10"
                    Stroke="Transparent" Margin="0,0,4,0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMonthlyTabTapped"/>
                </Border.GestureRecognizers>
                <VerticalStackLayout Padding="10,8" Spacing="1"
                                     HorizontalOptions="Center">
                    <Label x:Name="MonthlyTabLabel"
                           Text="📅 Monthly"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"/>
                    <Label x:Name="MonthlyPeriodLabel"
                           FontSize="10" TextColor="#E0F7F5"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- Weekly Tab -->
            <Border x:Name="WeeklyTabBorder"
                    Grid.Column="1"
                    BackgroundColor="#F0F4F4"
                    StrokeShape="RoundRectangle 10"
                    Stroke="Transparent" Margin="4,0,0,0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnWeeklyTabTapped"/>
                </Border.GestureRecognizers>
                <VerticalStackLayout Padding="10,8" Spacing="1"
                                     HorizontalOptions="Center">
                    <Label x:Name="WeeklyTabLabel"
                           Text="📆 Weekly"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="#9898A6"
                           HorizontalOptions="Center"/>
                    <Label x:Name="WeeklyPeriodLabel"
                           FontSize="10" TextColor="#9898A6"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ── CONTENT ── -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="16,12,16,20" Spacing="12">

                <!-- Period Navigator (prev/next) -->
                <Grid ColumnDefinitions="Auto,*,Auto"
                      BackgroundColor="White"
                      Padding="8,8"
                      x:Name="NavigatorRow">
                    <Border Grid.Column="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPrevPeriod"/>
                        </Border.GestureRecognizers>
                        <Label Text="‹" FontSize="22" FontAttributes="Bold"
                               TextColor="#4ECDC4" Padding="10,0"/>
                    </Border>
                    <Label x:Name="PeriodRangeLabel"
                           Grid.Column="1"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="#2D2D35"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    <Border Grid.Column="2">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNextPeriod"/>
                        </Border.GestureRecognizers>
                        <Label Text="›" FontSize="22" FontAttributes="Bold"
                               TextColor="#4ECDC4" Padding="10,0"/>
                    </Border>
                </Grid>

                <!-- Summary Cards -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8"
                      x:Name="SummaryCards">
                    <Border Grid.Column="0" BackgroundColor="White"
                            StrokeShape="RoundRectangle 14"
                            Stroke="#EFEFEF" StrokeThickness="1"
                            Padding="12,10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="INCOME" FontSize="9" FontAttributes="Bold"
                                   TextColor="#9898A6" CharacterSpacing="1"/>
                            <Label x:Name="SummaryIncome" FontSize="14"
                                   FontAttributes="Bold" TextColor="#4ECDC4"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" BackgroundColor="White"
                            StrokeShape="RoundRectangle 14"
                            Stroke="#EFEFEF" StrokeThickness="1"
                            Padding="12,10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="SPENT" FontSize="9" FontAttributes="Bold"
                                   TextColor="#9898A6" CharacterSpacing="1"/>
                            <Label x:Name="SummarySpent" FontSize="14"
                                   FontAttributes="Bold" TextColor="#FF6B6B"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" BackgroundColor="White"
                            StrokeShape="RoundRectangle 14"
                            Stroke="#EFEFEF" StrokeThickness="1"
                            Padding="12,10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="LEFT" FontSize="9" FontAttributes="Bold"
                                   TextColor="#9898A6" CharacterSpacing="1"/>
                            <Label x:Name="SummaryLeft" FontSize="14"
                                   FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Tip Banner -->
                <Border BackgroundColor="#E8FBF8" StrokeShape="RoundRectangle 14"
                        Stroke="#4ECDC433" StrokeThickness="1" Padding="14,12">
                    <Label x:Name="TipLabel" FontSize="12" TextColor="#3D3D4E">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="⚡ Tip: " FontAttributes="Bold"/>
                                <Span Text="You'll get a warning at 80% and alert when exceeded."/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </Border>

                <!-- Budget Rows -->
                <Border BackgroundColor="White" StrokeShape="RoundRectangle 20"
                        Stroke="#EFEFEF" StrokeThickness="1" Padding="18">
                    <VerticalStackLayout x:Name="BudgetRowsStack" Spacing="16"/>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── SAVE BUTTON ── -->
        <Grid Grid.Row="3" BackgroundColor="White" Padding="16,12,16,32">
            <Border StrokeShape="RoundRectangle 14" Stroke="Transparent">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4ECDC4" Offset="0"/>
                        <GradientStop Color="#38b2aa" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Button Text="💾  Save Budgets" TextColor="White" FontSize="16"
                        FontAttributes="Bold" BackgroundColor="Transparent"
                        Clicked="OnSaveClicked"/>
            </Border>
        </Grid>

    </Grid>
</ContentPage>